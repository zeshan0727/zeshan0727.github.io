<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<array>
    <dict>
        <key>cell</key><string>PSGroupCell</string>
        <key>label</key><string>BOLD CARD STUDIO 0.3.1</string>
        <key>footerText</key><string>Native Concept D reconstruction for RootHide and iOS 16. The custom keypad is rendered by PhoneAura; Apple’s tab controller and system calling flows remain active for safe navigation.</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Enable PhoneAura</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>enabled</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Force Concept D Dark Mode</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>forceDark</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>

    <dict>
        <key>cell</key><string>PSGroupCell</string>
        <key>label</key><string>CONCEPT D LAYOUT</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Large Studio Headers</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>showSubtitles</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Smart Shortcut Cards</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>showShortcuts</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Native Concept D Keypad</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>styleKeypad</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSliderCell</string>
        <key>label</key><string>Card Opacity</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>cardOpacity</string>
        <key>default</key><real>0.96</real>
        <key>min</key><real>0.60</real>
        <key>max</key><real>1.00</real>
        <key>showValue</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSliderCell</string>
        <key>label</key><string>Card Corner Radius</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>cornerRadius</string>
        <key>default</key><real>16.0</real>
        <key>min</key><real>10.0</real>
        <key>max</key><real>24.0</real>
        <key>showValue</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>

    <dict>
        <key>cell</key><string>PSGroupCell</string>
        <key>label</key><string>FEEDBACK</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Haptic Feedback</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>haptics</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>
    <dict>
        <key>cell</key><string>PSSwitchCell</string>
        <key>label</key><string>Fluid Animations</string>
        <key>defaults</key><string>com.zeshan.phoneaura</string>
        <key>key</key><string>animations</string>
        <key>default</key><true/>
        <key>PostNotification</key><string>com.zeshan.phoneaura/preferences.changed</string>
    </dict>

    <dict>
        <key>cell</key><string>PSGroupCell</string>
        <key>footerText</key><string>Restart Phone after major layout changes. Disabling PhoneAura restores the system Phone interface without uninstalling the package.</string>
    </dict>
    <dict>
        <key>cell</key><string>PSButtonCell</string>
        <key>label</key><string>Restart Phone App</string>
        <key>action</key><string>restartPhoneApp</string>
    </dict>
    <dict>
        <key>cell</key><string>PSButtonCell</string>
        <key>label</key><string>Reset Concept D Settings</string>
        <key>action</key><string>resetPreferences</string>
    </dict>
    <dict>
        <key>cell</key><string>PSButtonCell</string>
        <key>label</key><string>Developer GitHub</string>
        <key>action</key><string>openGitHub</string>
    </dict>
</array>
</plist>
